# Example local dev environment variables for `wrangler dev`.
# Copy this file to `.dev.vars` (which is gitignored) and fill in real values.
# Do NOT commit `.dev.vars` or any real secrets.
#
# For production, use:
#   wrangler secret put MY_SECRET
#
# Variables defined here are exposed to the Worker as `env.<NAME>` at runtime.

APP_ENV="development"
APP_NAME="cloudflare-worker-boilerplate"
APP_VERSION="1.0.0"
LOG_LEVEL="debug"
ALLOWED_ORIGINS="*"

# Optional: when set, routes wrapped with API-key auth require this value.
# API_KEY="replace-me"

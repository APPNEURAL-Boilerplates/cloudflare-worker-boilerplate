{
  "name": "cloudflare-workers-typescript-microservice",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Production-ready Cloudflare Workers TypeScript microservice boilerplate.",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev --remote",
    "types": "wrangler types",
    "typecheck": "wrangler types && tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "clean": "rm -rf .wrangler dist coverage",
    "tail": "wrangler tail",
    "smoke": "node scripts/smoke-test.mjs",
    "check": "npm run typecheck && npm test",
    "ci": "npm run lint && npm run check"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.91.0"
  }
}

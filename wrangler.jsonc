{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloudflare-worker-boilerplate",
  "main": "src/index.ts",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  }
  // Add bindings here (KV, R2, D1, Queues, etc.) as your worker grows.
  // Secrets must NEVER be committed. Use `wrangler secret put <NAME>` or `.dev.vars` (gitignored) for local dev.
}
